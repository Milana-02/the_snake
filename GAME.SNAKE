import pygame as pg
import sys
import random

# Размеры окна и игровой сетки
SCREEN_WIDTH = 1000
SCREEN_HEIGHT = 600
GRID_SIZE = 20
GRID_WIDTH = (SCREEN_WIDTH - 400) // GRID_SIZE
GRID_HEIGHT = SCREEN_HEIGHT // GRID_SIZE
INFO_AREA_WIDTH = 400
# палитра
BLACK = (0, 0, 0)
WHITE = (255, 255, 255)
RED = (255, 0, 0)
BLUE = (0, 0, 255)
LIGHT_GRAY = (200, 200, 200)
LIGHT_GREEN = (155, 188, 15)
DARK_GREEN = (15, 56, 15)
BOARD_BACKGROUND_COLOR = LIGHT_GREEN
# Константы направлений
UP = (0, -1)
DOWN = (0, 1)
LEFT = (-1, 0)
RIGHT = (1, 0)

# Словарь управления движениями
MOVEMENT_KEYS = {
    pg.K_UP: UP,
    pg.K_DOWN: DOWN,
    pg.K_LEFT: LEFT,
    pg.K_RIGHT: RIGHT,
}

# Глобальные переменные
score = 0
screen = pg.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pg.time.Clock()
